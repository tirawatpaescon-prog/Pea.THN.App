rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isStaff() { return isSignedIn() && request.auth.token.role == 'staff'; }
    function isInstaller() { return isSignedIn() && request.auth.token.role == 'installer'; }
    function isCustomer() { return isSignedIn() && request.auth.token.role == 'customer'; }

    match /requests/{requestId} {
      allow create: if isAdmin() || isStaff() || isInstaller();
      allow read: if isAdmin() || isStaff() || isInstaller() || isCustomer();
      allow update: if isAdmin() || isStaff() || isInstaller();
      allow delete: if false;
    }

    match /global_data/{docId} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    match /meterUserRegistrations/{registrationId} {
      allow create: if !isSignedIn() || isCustomer();
      allow read: if isAdmin() || (isCustomer() && request.auth.uid == resource.data.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /refundRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.depositAmount is number;
      allow read: if request.auth.uid == resource.data.userId || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
